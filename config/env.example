# Broker
MQTT_URL=wss://example-broker:8084/mqtt
MQTT_USERNAME=replace_me
MQTT_PASSWORD=replace_me

# Workspace
WORKSPACE_TOPIC_SALT=replace_with_random_hex
WORKSPACE_KEY_VERSION=1

# Feature flags
FEATURE_AUTO_SYNC=true
FEATURE_SENSITIVE_FILTER=true
FEATURE_MANUAL_OVERRIDE=true
FEATURE_WEBDEV=false
WEBDEV_MODE=off
WEBDEV_ASSET_BASE_URL=http://localhost:5173

# Custom sync server (requires /start-service endpoint on that server)
CUSTOM_SYNC_SERVER_ENABLED=false
CUSTOM_SYNC_SERVER_BASE_URL=http://localhost:8787
CUSTOM_SYNC_SERVER_AUTO_START=true
CUSTOM_SYNC_SERVER_HEALTH_PATH=/health
CUSTOM_SYNC_SERVER_START_PATH=/start-service

# Android release signing
ANDROID_RELEASE_STORE_FILE=
ANDROID_RELEASE_STORE_PASSWORD=
ANDROID_RELEASE_KEY_ALIAS=
ANDROID_RELEASE_KEY_PASSWORD=

# Logging
LOG_LEVEL=info
LOG_REDACT_PAYLOAD=true
